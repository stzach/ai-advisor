{
  "name": "aiadvisor.web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "run-script-os",
    "prestart": "npm run generate-api",
    "start:windows": "ng serve --port %PORT%",
    "start:default": "ng serve --port $PORT",
    "prebuild": "npm run generate-api && (npx kendo-ui-license activate || echo Kendo license activation skipped)",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate-api": "nswag run /runtime:Net100"
  },
  "private": true,
