    "@angular/localize": "^21.2.12",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/platform-server": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@microsoft/signalr": "^10.0.0",
    "@picocss/pico": "^2.0.0",
    "@progress/kendo-angular-buttons": "^23.4.0",
    "@progress/kendo-angular-charts": "^23.4.0",
    "@progress/kendo-angular-common": "^23.4.0",
    "@progress/kendo-angular-conversational-ui": "^23.4.0",
    "@progress/kendo-angular-dateinputs": "^23.4.0",
